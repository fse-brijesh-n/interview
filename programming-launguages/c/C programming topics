Part 5: Data Structures & Algorithms in C (Interview Essentials)

5.1 Linked List

```c
struct Node {
    int data;
    struct Node *next;
};

struct Node* insertHead(struct Node *head, int data) {
    struct Node *newNode = malloc(sizeof(struct Node));
    newNode->data = data;
    newNode->next = head;
    return newNode;
}

void reverse(struct Node **head) {
    struct Node *prev = NULL, *current = *head, *next;
    while (current) {
        next = current->next;
        current->next = prev;
        prev = current;
        current = next;
    }
    *head = prev;
}
```

5.2 Stack (Array & Linked List)

```c
// Array-based stack
#define MAX 100
int stack[MAX];
int top = -1;
void push(int x) { stack[++top] = x; }
int pop() { return stack[top--]; }
```

5.3 Queue (Circular Buffer)

```c
#define SIZE 10
int queue[SIZE], front = 0, rear = -1, count = 0;
void enqueue(int x) {
    if (count == SIZE) return; // full
    rear = (rear + 1) % SIZE;
    queue[rear] = x;
    count++;
}
int dequeue() {
    if (count == 0) return -1; // empty
    int x = queue[front];
    front = (front + 1) % SIZE;
    count--;
    return x;
}
```

5.4 Binary Search Tree

```c
struct TreeNode {
    int data;
    struct TreeNode *left, *right;
};
struct TreeNode* insert(struct TreeNode *root, int key) {
    if (!root) {
        root = malloc(sizeof(struct TreeNode));
        root->data = key; root->left = root->right = NULL;
        return root;
    }
    if (key < root->data) root->left = insert(root->left, key);
    else root->right = insert(root->right, key);
    return root;
}
```

